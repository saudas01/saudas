{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "A member of the SAUDAS charity organization.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the member."
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the member."
        },
        "address": {
          "type": "string",
          "description": "Address of the member."
        },
        "role": {
          "type": "string",
          "description": "Role of the member (e.g., Volunteer, Blood Donor)."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the member."
        },
        "bloodGroup": {
          "type": "string",
          "description": "Blood group of the member."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"],
          "description": "Approval status of the member."
        },
        "joinedAt": {
          "type": "integer",
          "description": "Timestamp when the member joined."
        }
      },
      "required": ["name", "phone", "address", "role", "joinedAt", "status"]
    },
    "Service": {
      "title": "Service",
      "description": "A service provided by the organization.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "images": {
          "type": "array",
          "items": { "type": "string" }
        },
        "icon": {
          "type": "string",
          "description": "Lucide icon name"
        },
        "color": {
          "type": "string"
        },
        "accent": {
          "type": "string"
        }
      },
      "required": ["title", "description", "images"]
    },
    "ActiveMember": {
      "title": "ActiveMember",
      "description": "A featured active member of the organization.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "order": {
          "type": "integer"
        }
      },
      "required": ["name", "role", "image", "order"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application, potentially an admin.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"]
        },
        "name": {
          "type": "string"
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Donation": {
      "title": "Donation",
      "description": "A donation record submitted by a user.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "amount": {
          "type": "string"
        },
        "lastFour": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "verified"]
        },
        "createdAt": {
          "type": "integer"
        }
      },
      "required": ["name", "phone", "amount", "lastFour", "status", "createdAt"]
    },
    "Notice": {
      "title": "Notice",
      "description": "An official notice from the organization.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "integer" },
        "authorName": { "type": "string" }
      },
      "required": ["title", "content", "createdAt"]
    },
    "BloodPost": {
      "title": "BloodPost",
      "description": "A post requesting blood donation.",
      "type": "object",
      "properties": {
        "bloodGroup": { "type": "string" },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "description": { "type": "string" },
        "urgency": { "type": "string", "enum": ["normal", "urgent", "emergency"] },
        "createdAt": { "type": "integer" },
        "authorName": { "type": "string" },
        "authorId": { "type": "string" }
      },
      "required": ["bloodGroup", "location", "phone", "urgency", "createdAt"]
    },
    "BloodComment": {
      "title": "BloodComment",
      "description": "A comment on a blood donation post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "text": { "type": "string" },
        "authorName": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["postId", "text", "authorName", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in the community chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "authorName": { "type": "string" },
        "authorId": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["text", "authorName", "authorId", "createdAt"]
    },
    "SiteConfig": {
      "title": "SiteConfig",
      "description": "General site configuration and content.",
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "bgImage": { "type": "string" },
            "stats": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "label": { "type": "string" },
                  "value": { "type": "string" },
                  "icon": { "type": "string" }
                }
              }
            }
          }
        },
        "about": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "storyTitle": { "type": "string" },
            "storyContent": { "type": "string" }
          }
        },
        "contact": {
          "type": "object",
          "properties": {
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "payment": {
          "type": "object",
          "properties": {
            "treasurerName": { "type": "string" },
            "treasurerRole": { "type": "string" },
            "bkash": { "type": "string" },
            "nagad": { "type": "string" },
            "rocket": { "type": "string" }
          }
        }
      }
    },
    "Event": {
      "title": "Event",
      "description": "An event organized by the charity.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["title", "date", "time", "location", "description", "createdAt"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of charity members."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of services."
    },
    "/active_members/{memberId}": {
      "schema": "ActiveMember",
      "description": "Collection of featured active members."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users and their roles."
    },
    "/donations/{donationId}": {
      "schema": "Donation",
      "description": "Collection of donation submissions."
    },
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "Collection of official notices."
    },
    "/blood_posts/{postId}": {
      "schema": "BloodPost",
      "description": "Collection of blood donation requests."
    },
    "/blood_comments/{commentId}": {
      "schema": "BloodComment",
      "description": "Collection of comments on blood posts."
    },
    "/chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Collection of community chat messages."
    },
    "/site_config/{configId}": {
      "schema": "SiteConfig",
      "description": "Collection for site content and configuration."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Collection of charity events."
    }
  }
}
